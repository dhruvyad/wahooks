# ─── Database ──────────────────────────────────────────────
# Supabase Postgres connection string
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ─── Authentication ───────────────────────────────────────
# Supabase project URL (from Supabase dashboard → Settings → API)
# JWTs are verified via JWKS at {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_URL=https://xxx.supabase.co

# ─── Orchestration ─────────────────────────────────────────
# Which orchestrator to use: k8s (default in production), hetzner (legacy), mock (dev)
ORCHESTRATOR=mock
NODE_ENV=development

# ─── Kubernetes (ORCHESTRATOR=k8s) ─────────────────────────
# Shared API key for all WAHA pods (must match the waha-secret k8s Secret)
WAHA_API_KEY=your-waha-api-key
# K8S_NAMESPACE=default
# WAHA_STATEFULSET_NAME=waha
# WAHA_HEADLESS_SERVICE=waha
# KUBECONFIG=~/.kube/wahooks.yaml       # only needed when running outside the cluster

# ─── Hetzner Cloud (ORCHESTRATOR=hetzner, legacy) ──────────
# HETZNER_API_TOKEN=your-hetzner-api-token
# HETZNER_NETWORK_ID=your-network-id
# HETZNER_SERVER_TYPE=cx23
# HETZNER_LOCATION=nbg1

# ─── WAHA ────────────────────────────────────────────────
# Max sessions per worker: 1 for WAHA Core (free), 50 for WAHA Plus
WAHA_MAX_SESSIONS=1

# ─── Stripe Billing ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── URLs ─────────────────────────────────────────────────
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── Redis (BullMQ) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379
