# ─── Database ──────────────────────────────────────────────
# Supabase Postgres connection string
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ─── Authentication ───────────────────────────────────────
# Supabase JWT secret (from Supabase dashboard → Settings → API)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Hetzner Cloud (production only) ─────────────────────
# Set NODE_ENV=production to use real Hetzner orchestration
NODE_ENV=development
HETZNER_API_TOKEN=your-hetzner-api-token
HETZNER_NETWORK_ID=your-network-id
HETZNER_SERVER_TYPE=cx22
HETZNER_LOCATION=fsn1

# ─── Stripe Billing ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── URLs ─────────────────────────────────────────────────
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── Redis (BullMQ) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379
